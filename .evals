# ==========================================
# Test Infrastructure
# ==========================================
# LLM test fixtures - run related tests
tests/llm/fixtures/test_ask_holmes/09_crashpod/**:09_crashpod
tests/llm/fixtures/test_ask_holmes/101_loki_historical_logs_pod_deleted/**:101_loki_historical_logs_pod_deleted

# Shared test infrastructure - run all easy tests
tests/llm/fixtures/shared/**:easy
